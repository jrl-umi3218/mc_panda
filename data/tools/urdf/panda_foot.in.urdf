<?xml version="1.0" encoding="utf-8"?>
<robot name="panda_foot">
  <link name="tool_connector"></link>
  <joint name="panda_foot_joint" type="fixed">
    <parent link="tool_connector"/>
    <child link="panda_foot"/>
    <origin rpy="0 0 -0.7853981633974483" xyz="0 0 0"/>
  </joint>
  <link name="panda_foot">
    <inertial>
      <mass value="0.1"/>
      <origin rpy="0 0 0" xyz="0 0 0.01"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="file://@MODULE_INSTALL_LOCATION@/meshes/panda_foot/foot.stl"/>
      </geometry>
      <material name="">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="file://@MODULE_INSTALL_LOCATION@/meshes/panda_foot/foot.stl"/>
      </geometry>
    </collision>
  </link>
</robot>
